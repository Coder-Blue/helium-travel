{
  "name": "helium-nuxt",
  "type": "module",
  "version": "0.1.3",
  "private": true,
  "description": "A travel log app built with Nuxt",
  "author": {
    "name": "Noah Trần",
    "url": "https://github.com/Coder-Blue"
  },
  "license": "MIT",
  "scripts": {
    "build": "nuxt build --preset=vercel_edge",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/eslint": "1.7.1",
    "eslint": "^9.32.0",
    "nuxt": "^4.0.2",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.0.0",
    "eslint-plugin-format": "^1.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@latest"
    }
  },
  "lint-staged": {
    "*": "pnpm lint"
  }
}
